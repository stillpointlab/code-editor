{
  "name": "@stillpointlab/code-editor",
  "version": "0.1.0",
  "description": "A CodeMirror-based code editor web component (<code-editor>) with syntax highlighting and line numbers.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./src/index.ts",
    "./src/editor/code-editor.ts",
    "./src/preview/index.ts",
    "./src/preview/code-preview.ts",
    "./src/diff/index.ts",
    "./src/diff/code-diff.ts",
    "./dist/index.js",
    "./dist/index.cjs",
    "./dist/preview.js",
    "./dist/preview.cjs",
    "./dist/diff.js",
    "./dist/diff.cjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "import": "./dist/preview.js",
      "require": "./dist/preview.cjs"
    },
    "./diff": {
      "types": "./dist/diff.d.ts",
      "import": "./dist/diff.js",
      "require": "./dist/diff.cjs"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "preview.d.ts",
    "diff.d.ts"
  ],
  "scripts": {
    "gen:styles": "node scripts/gen-styles.mjs",
    "prepare": "npm run build",
    "build": "npm run gen:styles && tsup",
    "dev": "npm run gen:styles && vite",
    "typecheck": "npm run gen:styles && tsc --noEmit",
    "test": "npm run gen:styles && vitest run",
    "lint": "eslint .",
    "format": "prettier --check \"**/*.{ts,mjs,json,md,scss,css,html}\"",
    "format:fix": "prettier --write \"**/*.{ts,mjs,json,md,scss,css,html}\""
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.10.8",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.43.6",
    "@replit/codemirror-vim": "^6.3.0",
    "codemirror": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-import-x": "^4.17.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.5.3",
    "sass": "^1.86.3",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
